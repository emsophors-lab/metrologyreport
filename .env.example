# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE CONNECTION (Required for Production Database integration on Vercel / GitHub)
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-public-anon-key"

# Enable demo testing credentials for local/previews
VITE_ENABLE_DEMO_LOGIN=true

# Local legacy API auth compatibility only. Keep disabled in production.
ALLOW_LEGACY_API_HEADER_AUTH=false
VITE_ALLOW_LEGACY_API_HEADER_AUTH=false

# FRONTEND TELEGRAM CONFIGURATION
# NOTE: Frontend variables start with VITE_; they are exposed to the client in the browser.
VITE_TELEGRAM_BOT_USERNAME="NMC_License_Reminder_Bot"

# OpenStreetMap Tile Configuration (Leaflet map default integration doesn't require paid API keys)
# For high-volume production, NMC may configure custom self-hosted or dedicated tile servers here if needed.

# SERVER-SIDE ONLY CONFIGURATIONS
# WARNING: Secret variables must never be exposed in frontend code.
# Supabase service role key must never be used in browser/client code.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Telegram bot secrets (used exclusively in backend/serverless functions)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_BOT_USERNAME="NMC_License_Reminder_Bot"

# Optional: separate Telegram bots by purpose
TELEGRAM_REPORT_BOT_TOKEN="your-report-group-bot-token"
TELEGRAM_REPORT_BOT_USERNAME="NMC_Report_Notification_Bot"
TELEGRAM_REPORT_CHAT_ID="-1001234567890"
TELEGRAM_REMINDER_BOT_TOKEN="your-company-reminder-bot-token"
TELEGRAM_REMINDER_BOT_USERNAME="NMC_License_Reminder_Bot"

# Webhook protection & secure cron trigger signatures
TELEGRAM_WEBHOOK_SECRET="your-webhook-secret-token"
CRON_SECRET="your-weekly-or-daily-cron-secret"
